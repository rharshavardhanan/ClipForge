# === Semantic scoring providers ===
# Claude is the PRIMARY (highest-accuracy) semantic brain: viral scoring, hook
# extraction, clip titles. Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Thinking/output depth: low | medium | high | xhigh | max
ANTHROPIC_EFFORT=medium

# Gemini Flash is the REDUNDANT fallback — used only when no Anthropic key is set,
# or Claude returns nothing. One key, or several to multiply free-tier quota.
GEMINI_API_KEY=
# Optional: comma-separated list of multiple free-tier Gemini API keys. When set, ClipForge
# round-robins across them and rotates off any key that hits a 429/quota error, multiplying
# the effective free-tier rate limit and daily quota. Falls back to GEMINI_API_KEY if unset.
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# === Paths & logging ===
WORKSPACE_DIR=./workspace
MUSIC_DIR=./music
LOG_LEVEL=info
