# === Semantic scoring providers ===
# Claude is the PRIMARY (highest-accuracy) semantic brain: viral scoring, hook
# extraction, clip titles. Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Thinking/output depth: low | medium | high | xhigh | max
ANTHROPIC_EFFORT=medium

# Force a provider: auto (default) | claude | gemini | none.
#   gemini = always use the FREE Gemini path (get a free key at aistudio.google.com/apikey)
#   none   = skip the LLM entirely (audio + linguistic-trigger scoring only, fully offline)
SEMANTIC_PROVIDER=auto

# Gemini Flash is the FREE provider — set this and SEMANTIC_PROVIDER=gemini for zero-cost
# scoring. Also the automatic fallback when no Anthropic key is set. One key, or several
# comma-separated to multiply the free-tier quota.
GEMINI_API_KEY=
# Optional: comma-separated list of multiple free-tier Gemini API keys. When set, ClipForge
# round-robins across them and rotates off any key that hits a 429/quota error, multiplying
# the effective free-tier rate limit and daily quota. Falls back to GEMINI_API_KEY if unset.
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# === YouTube publishing (clipforge auth youtube / clipforge upload) ===
# Create a FREE "Desktop app" OAuth client at console.cloud.google.com/apis/credentials
# (first enable "YouTube Data API v3" in that project's API Library, and add your Gmail
# as a Test user on the OAuth consent screen).
# Note: until you "Publish app" + verify it, YouTube locks API uploads to private —
# flip them public in YouTube Studio, or verify the app once to remove the limit.
YT_CLIENT_ID=
YT_CLIENT_SECRET=

# === Perception (optional, opt-in via --perception or PERCEPTION=1) ===
# FREE Hugging Face token — unlocks PyAnnote speaker diarization in the perception pass.
# Get one at hf.co/settings/tokens, then (while logged in) accept the model terms at
# hf.co/pyannote/speaker-diarization-3.1 AND hf.co/pyannote/segmentation-3.0.
# Without it the pyannote producer is skipped (fail-soft); yamnet/clip still run.
HF_TOKEN=

# === Paths & logging ===
WORKSPACE_DIR=./workspace
MUSIC_DIR=./music
# Sound-design one-shots: sfx/whoosh/*.mp3, sfx/impact/*.mp3 (or whoosh_*.mp3 prefixed files).
# whoosh = punch zooms, impact = hook card. Empty folder → SFX silently skipped.
SFX_DIR=./sfx
LOG_LEVEL=info
